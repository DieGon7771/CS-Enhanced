<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/primaryGrayBackground"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- TITOLO -->
    <TextView
        android:id="@+id/text1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:text="@string/add_repository"
        android:textColor="?attr/textColor"
        android:textSize="22sp"
        android:textStyle="bold" />

    <!-- NOME REPOSITORY -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Repository Name"
        android:textColor="?attr/textColor"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/repo_name_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:autofillHints="username"
        android:background="?attr/boxItemBackground"
        android:hint="@string/repository_name_hint"
        android:inputType="text"
        android:nextFocusDown="@id/repo_url_input"
        android:padding="16dp"
        android:textColor="?attr/textColor"
        android:textColorHint="?attr/grayTextColor"
        android:textSize="14sp"
        tools:ignore="LabelFor" />

    <!-- URL REPOSITORY -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Repository URL"
        android:textColor="?attr/textColor"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/repo_url_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:autofillHints="url"
        android:background="?attr/boxItemBackground"
        android:hint="@string/repository_url_hint"
        android:inputType="textUri"
        android:nextFocusUp="@id/repo_name_input"
        android:padding="16dp"
        android:textColor="?attr/textColor"
        android:textColorHint="?attr/grayTextColor"
        android:textSize="14sp"
        tools:ignore="LabelFor" />

    <!-- BOTTONI -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:paddingTop="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cancel_btt"
            style="@style/WhiteButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp"
            android:text="@string/sort_cancel"
            app:backgroundTint="?attr/boxItemBackground"
            app:strokeColor="?attr/colorPrimary"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/apply_btt"
            style="@style/WhiteButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/add_repository"
            android:textStyle="bold"
            app:backgroundTint="?attr/colorPrimary" />
    </LinearLayout>
</LinearLayout>
