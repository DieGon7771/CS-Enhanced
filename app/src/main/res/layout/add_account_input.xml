<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"> <!-- FIX: Padding uniforme -->

    <!-- INTESTAZIONE -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp" <!-- FIX: Margine consistente -->
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/text1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="?attr/textColor"
            android:textSize="22sp"
            android:textStyle="bold"
            tools:text="Account Login" /> <!-- FIX: Testo più descrittivo -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/create_account"
            style="@style/WhiteButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/create_account"
            app:icon="@drawable/ic_baseline_add_24"
            app:iconGravity="textStart" /> <!-- FIX: Icona allineata -->
    </LinearLayout>

    <!-- FORM INPUTS - MIGLIORATO -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingHorizontal="4dp"> <!-- FIX: Padding leggero -->

        <!-- USERNAME -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxBackgroundColor="?attr/boxItemBackground"
            app:hintTextColor="?attr/grayTextColor">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/login_username_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="username"
                android:hint="@string/example_username"
                android:inputType="text"
                android:textColor="?attr/textColor"
                android:textColorHint="?attr/grayTextColor" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- EMAIL -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxBackgroundColor="?attr/boxItemBackground"
            app:hintTextColor="?attr/grayTextColor">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/login_email_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="emailAddress"
                android:hint="@string/example_email"
                android:inputType="textEmailAddress"
                android:textColor="?attr/textColor"
                android:textColorHint="?attr/grayTextColor" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- SERVER -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxBackgroundColor="?attr/boxItemBackground"
            app:hintTextColor="?attr/grayTextColor">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/login_server_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="url"
                android:hint="@string/example_ip"
                android:inputType="textUri"
                android:textColor="?attr/textColor"
                android:textColorHint="?attr/grayTextColor" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- PASSWORD -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxBackgroundColor="?attr/boxItemBackground"
            app:hintTextColor="?attr/grayTextColor"
            app:endIconMode="password_toggle"> <!-- FIX: Icona show/hide password -->

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/login_password_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="password"
                android:hint="@string/example_password"
                android:inputType="textPassword"
                android:textColor="?attr/textColor"
                android:textColorHint="?attr/grayTextColor" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <!-- BOTTONI - POSIZIONATI CORRETTAMENTE -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:paddingTop="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cancel_btt"
            style="@style/WhiteButton"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:layout_marginEnd="12dp"
            android:text="@string/sort_cancel"
            android:textColor="?attr/colorPrimary" <!-- FIX: Testo visibile -->
            app:backgroundTint="?attr/boxItemBackground"
            app:strokeColor="?attr/colorPrimary"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/apply_btt"
            style="@style/WhiteButton"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:text="@string/login"
            android:textStyle="bold"
            app:backgroundTint="?attr/colorPrimary" />
    </LinearLayout>
</LinearLayout>
