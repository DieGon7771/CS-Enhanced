<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/primaryGrayBackground"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- TITOLO -->
    <TextView
        android:id="@+id/text1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:textColor="?attr/textColor"
        android:textSize="22sp"
        android:textStyle="bold"
        tools:text="Account Login" />

    <!-- USERNAME -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/username_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:hint="@string/example_username"
        app:boxBackgroundMode="outline"
        app:boxBackgroundColor="?attr/boxItemBackground"
        app:hintTextColor="?attr/grayTextColor"
        app:startIconDrawable="@drawable/ic_baseline_person_24"
        app:startIconTint="?attr/iconColor">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/login_username_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:autofillHints="username"
            android:inputType="text"
            android:nextFocusDown="@id/email_container"
            android:textColor="?attr/textColor"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- EMAIL -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/email_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:hint="@string/example_email"
        app:boxBackgroundMode="outline"
        app:boxBackgroundColor="?attr/boxItemBackground"
        app:hintTextColor="?attr/grayTextColor"
        app:startIconDrawable="@drawable/ic_baseline_email_24"
        app:startIconTint="?attr/iconColor">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/login_email_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:autofillHints="emailAddress"
            android:inputType="textEmailAddress"
            android:nextFocusDown="@id/server_container"
            android:nextFocusUp="@id/username_container"
            android:textColor="?attr/textColor"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- SERVER (opzionale, probabilmente) -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/server_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:hint="@string/example_ip"
        app:boxBackgroundMode="outline"
        app:boxBackgroundColor="?attr/boxItemBackground"
        app:hintTextColor="?attr/grayTextColor"
        app:startIconDrawable="@drawable/ic_baseline_dns_24"
        app:startIconTint="?attr/iconColor">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/login_server_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:autofillHints="url"
            android:inputType="textUri"
            android:nextFocusDown="@id/password_container"
            android:nextFocusUp="@id/email_container"
            android:textColor="?attr/textColor"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- PASSWORD -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/password_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        app:hint="@string/example_password"
        app:boxBackgroundMode="outline"
        app:boxBackgroundColor="?attr/boxItemBackground"
        app:hintTextColor="?attr/grayTextColor"
        app:startIconDrawable="@drawable/ic_baseline_lock_24"
        app:startIconTint="?attr/iconColor"
        app:endIconMode="password_toggle"
        app:endIconTint="?attr/iconColor">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/login_password_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:autofillHints="password"
            android:inputType="textPassword"
            android:nextFocusUp="@id/server_container"
            android:textColor="?attr/textColor"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- BOTTONI -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="space_between"
        android:paddingTop="8dp">

        <!-- BOTTONE CREA ACCOUNT -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/create_account"
            style="@style/WhiteButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:minWidth="140dp"
            android:text="@string/create_account"
            android:textAllCaps="false"
            app:backgroundTint="?attr/boxItemBackground"
            app:icon="@drawable/ic_baseline_add_24"
            app:strokeColor="?attr/colorPrimary"
            app:strokeWidth="1dp" />

        <!-- BOTTONI LOGIN/CANCEL -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cancel_btt"
                style="@style/WhiteButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginEnd="12dp"
                android:minWidth="100dp"
                android:text="@string/sort_cancel"
                android:textAllCaps="false"
                app:backgroundTint="?attr/boxItemBackground"
                app:strokeColor="?attr/colorPrimary"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/apply_btt"
                style="@style/WhiteButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:minWidth="100dp"
                android:text="@string/login"
                android:textAllCaps="false"
                android:textStyle="bold"
                app:backgroundTint="?attr/colorPrimary" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
