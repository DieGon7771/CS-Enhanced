<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/primaryBlackBackground"
    android:clipToPadding="false"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".ui.settings.extensions.PluginDetailsFragment">

    <!-- INTESTAZIONE -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="16dp">

        <!-- ICONA - FIX: Aggiunto android:src -->
        <androidx.cardview.widget.CardView
            android:layout_width="56dp"
            android:layout_height="56dp"
            app:cardCornerRadius="28dp"
            app:cardBackgroundColor="?attr/colorPrimary">

            <ImageView
                android:id="@+id/plugin_icon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="14dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_baseline_extension_24" <!-- FIX: android:src invece di tools:src -->
                app:tint="@android:color/white"
                tools:ignore="ContentDescription" />
        </androidx.cardview.widget.CardView>

        <!-- NOME -->
        <TextView
            android:id="@+id/plugin_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="?attr/textColor"
            android:textSize="20sp"
            android:textStyle="bold"
            tools:text="Plugin Name" />

        <!-- BOTTONI -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/action_settings"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/title_settings"
                android:focusable="true"
                android:padding="10dp"
                android:visibility="gone"
                app:srcCompat="@drawable/ic_baseline_tune_24"
                app:tint="?attr/iconColor"
                tools:visibility="visible" />

            <ImageView
                android:id="@+id/github_btn"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:focusable="true"
                android:padding="10dp"
                app:srcCompat="@drawable/ic_github_logo"
                app:tint="?attr/iconColor" />
        </LinearLayout>
    </LinearLayout>

    <!-- DESCRIZIONE (SEPARATA) - Migliorato per contenuto lungo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/boxItemBackground"
        android:padding="16dp"
        android:layout_marginBottom="12dp"
        android:elevation="2dp"
        android:minHeight="80dp"> <!-- FIX: Altezza minima per contenuto breve -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/extension_description"
            android:textColor="?attr/colorPrimary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/plugin_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="?attr/textColor"
            android:textSize="14sp"
            android:lineSpacingExtra="4sp" <!-- FIX: Aumentato spacing per leggibilità -->
            android:maxLines="20" <!-- FIX: Limite massimo linee -->
            android:scrollbars="vertical" <!-- FIX: Abilita scroll se necessario -->
            tools:text="This is a plugin description that explains what this extension does in detail." />
    </LinearLayout>

    <!-- INFO PRINCIPALI (IN 2 COLONNE) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <!-- COLONNA SINISTRA -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="?attr/boxItemBackground"
            android:padding="16dp"
            android:elevation="2dp"
            android:layout_marginEnd="6dp">

            <!-- AUTORE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/extension_authors"
                android:textColor="?attr/grayTextColor"
                android:textSize="12sp"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/plugin_author"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/textColor"
                android:textSize="14sp"
                android:paddingBottom="12dp"
                tools:text="Author Name" />

            <!-- STATO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/extension_status"
                android:textColor="?attr/grayTextColor"
                android:textSize="12sp"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/plugin_status"
                android:layout_width="wrap_content"
 android:layout_height="wrap_content"
                android:textColor="?attr/colorPrimary"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="Installed" />
        </LinearLayout>

        <!-- COLONNA DESTRA -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="?attr/boxItemBackground"
            android:padding="16dp"
            android:elevation="2dp"
            android:layout_marginStart="6dp">

            <!-- VERSIONE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/extension_version"
                android:textColor="?attr/grayTextColor"
                android:textSize="12sp"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/plugin_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/textColor"
                android:textSize="14sp"
                android:paddingBottom="12dp"
                tools:text="v1.2.3" />

            <!-- DIMENSIONE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/extension_size"
                android:textColor="?attr/grayTextColor"
                android:textSize="12sp"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/plugin_size"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/textColor"
                android:textSize="14sp"
                tools:text="2.4 MB" />
        </LinearLayout>
    </LinearLayout>

    <!-- TIPI E LINGUA -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/boxItemBackground"
        android:padding="16dp"
        android:layout_marginBottom="16dp"
        android:elevation="2dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/extension_types"
            android:textColor="?attr/grayTextColor"
            android:textSize="12sp"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/plugin_types"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/textColor"
            android:textSize="14sp"
            android:paddingBottom="12sp"
            tools:text="Movies, TV Series, Anime" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/extension_language"
            android:textColor="?attr/grayTextColor"
            android:textSize="12sp"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/plugin_lang"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/textColor"
            android:textSize="14sp"
            tools:text="English, Spanish, French" />
    </LinearLayout>

    <!-- VOTI - FIX COMPLETO: Rimosso background colorato, migliorato contrasto -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="?attr/boxItemBackground" <!-- FIX: Background uniforme -->
        android:padding="8dp"
        android:elevation="2dp">

        <TextView
            android:id="@+id/plugin_votes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="?attr/textColor"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingEnd="16dp" />

        <!-- FIX: Bottone like con stato chiaro -->
        <androidx.cardview.widget.CardView
            android:layout_width="52dp"
            android:layout_height="52dp"
            app:cardCornerRadius="26dp"
            app:cardBackgroundColor="?attr/boxItemBackground"
            app:cardElevation="2dp">

            <ImageView
                android:id="@+id/upvote"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="Upvote"
                android:focusable="true"
                android:padding="14dp"
                android:background="?attr/selectableItemBackground" <!-- FIX: Ripple effect -->
                app:srcCompat="@drawable/ic_baseline_thumb_up_24"
                app:tint="?attr/colorPrimary" /> <!-- FIX: Colore normale -->
        </androidx.cardview.widget.CardView>
    </LinearLayout>

</LinearLayout>
